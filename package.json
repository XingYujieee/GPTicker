{
  "name": "gpticker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json && node node_modules/vite/bin/vite.js build",
    "analyze": "OPEN_VISUALIZER=0 ANALYZE=true node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json && OPEN_VISUALIZER=0 ANALYZE=true node node_modules/vite/bin/vite.js build && node scripts/analyze.mjs",
    "dev": "node node_modules/vite/bin/vite.js build --watch",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "echarts": "^5.6.0",
    "postprocessing": "^6.38.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.285",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
