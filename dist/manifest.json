{
  "manifest_version": 3,
  "name": "GPTicker",
  "version": "0.1.0",
  "description": "GPTicker 为 ChatGPT 对话提供 Shadow DOM 隔离的导航与洞察侧栏。",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content-loader.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "assets/*.js", "assets/*.css"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ]
}
